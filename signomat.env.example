# Sign-O-Mat camera overrides
#
# Leave SIGNOMAT_CAMERA_BACKEND as "auto" to prefer Picamera2 when a Pi camera
# is available and fall back to OpenCV/V4L2 for USB cameras.

SIGNOMAT_CAMERA_BACKEND=auto

# For OpenCV/V4L2 cameras, set this to a device path like /dev/video0 or an
# integer camera index like 0.
# SIGNOMAT_CAMERA_DEVICE=/dev/video0

# For Picamera2, choose a camera number when multiple sensors are present.
# SIGNOMAT_CAMERA_INDEX=0

SIGNOMAT_CAMERA_WIDTH=1280
SIGNOMAT_CAMERA_HEIGHT=720
SIGNOMAT_CAMERA_FPS=30

# Some USB cameras need MJPG for higher resolutions/frame rates.
# SIGNOMAT_CAMERA_FOURCC=MJPG

# Increase if a camera needs more time before the first stable frame.
SIGNOMAT_CAMERA_WARMUP_SECONDS=2
SIGNOMAT_LOW_MEMORY_WARN_MB=512

# Keep runtime capture focused on higher-confidence signs. Lower these only
# when intentionally gathering review data.
SIGNOMAT_SAVE_CROPS=false
SIGNOMAT_SAVE_UNKNOWN_SIGNS=true
SIGNOMAT_MIN_BOX_AREA=900
SIGNOMAT_MIN_DETECTOR_CONFIDENCE=0.6
SIGNOMAT_MIN_CLASSIFIER_CONFIDENCE=0.75

# Cloudflare sync target. Enable when the Pi should push archive metadata to
# the deployed Worker API.
# SIGNOMAT_SYNC_ENABLED=true
# SIGNOMAT_SYNC_BASE_URL=https://signomat-api.<your-subdomain>.workers.dev
# SIGNOMAT_INGEST_TOKEN=replace-with-your-worker-secret
# SIGNOMAT_SYNC_DEVICE_ID=signomat-pi
